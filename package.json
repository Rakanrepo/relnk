{
  "name": "relnk",
  "version": "1.0.2",
  "description": "Relnk for any LLM: observe request/response and complete or forward. Works with OpenAI, Anthropic, and any provider.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test test/observe.test.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "relnk",
    "llm",
    "openai",
    "anthropic",
    "middleware",
    "observability"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "openai": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "openai": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "openai": "^4.52.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18"
  }
}
